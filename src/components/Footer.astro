---
const today = new Date();
---

<footer>
	<div class="footer-container">
		<span class="sys-status">[STATUS: ACTIVE]</span>
		<p>seferovic // {today.getFullYear()}</p>
	</div>
</footer>

<style>
	footer {
		border-top: 1px solid var(--border-color);
		padding: 2rem 0;
		background: var(--panel-color);
		color: var(--text-muted);
		font-family: var(--font-mono);
		font-size: 0.8rem;
		margin-top: 5rem;
	}
	.footer-container {
		max-width: 800px;
		margin: 0 auto;
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 0 1.5rem;
	}
	footer p {
		margin: 0;
	}
	.sys-status {
		color: var(--accent-green);
		font-weight: bold;
	}
</style>