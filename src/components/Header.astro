---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
---

<header>
	<nav class="nav-container">
		<div class="brand">
			<a href="/" class="brand-link">{SITE_TITLE.toLowerCase()}</a>
		</div>
		<div class="internal-links">
			<HeaderLink href="/">~/ana-sayfa</HeaderLink>
			<HeaderLink href="/blog">~/materyaller</HeaderLink>
			<HeaderLink href="/links">~/bağlantılar</HeaderLink>
			<HeaderLink href="/problems">~/problems</HeaderLink>
			<HeaderLink href="/contact">~/iletisim</HeaderLink> </div>
	</nav>
</header>

<style>
	header {
		border-bottom: 1px solid var(--border-color);
		background-color: var(--panel-color);
		padding: 1.2rem 0;
	}
	.nav-container {
		max-width: 800px;
		margin: 0 auto;
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 0 1.5rem;
	}
	.brand-link {
		color: var(--accent-green) !important;
		font-weight: 700;
		font-family: var(--font-mono);
		font-size: 1rem;
		text-decoration: none;
		letter-spacing: -0.5px;
	}
	.internal-links {
		display: flex;
		gap: 1.5rem;
	}
	.internal-links a {
		color: var(--text-muted);
		font-family: var(--font-mono);
		font-size: 0.85rem;
		text-decoration: none;
		transition: color 0.1s ease;
	}
	.internal-links a:hover,
	.internal-links a.active {
		color: var(--accent-green);
	}
	@media (max-width: 600px) {
		header {
			padding: 1rem 0;
		}
		.internal-links {
			display: flex;
			flex-wrap: wrap; /* Taşarsa alta atsın */
			justify-content: center;
			gap: 0.5rem;
		}
	}
</style>