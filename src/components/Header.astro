---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
---

<header>
	<nav class="nav-container">
		<div class="brand">
			<a href="/" style="color: var(--accent-green); font-weight: bold; font-family: var(--font-mono);">{SITE_TITLE}</a>
		</div>
		<div class="internal-links">
			<HeaderLink href="/">~/ana-sayfa</HeaderLink>
			<HeaderLink href="/blog">~/materyaller</HeaderLink>
			<HeaderLink href="/links">~/bağlantılar</HeaderLink>
			<HeaderLink href="/hof">~/hof</HeaderLink>
		</div>
	</nav>
</header>

<style>
	header {
		border-bottom: 1px solid var(--border-color);
		background-color: var(--panel-color);
		padding: 1rem 0;
	}
	.nav-container {
		max-width: 800px;
		margin: 0 auto;
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 0 1rem;
	}
	header a {
		color: var(--text-muted);
		font-family: var(--font-mono);
		font-size: 0.9rem;
		margin-right: 1rem;
		text-decoration: none;
	}
	header a.active, header a:hover {
		color: var(--accent-green);
	}
	.internal-links {
		display: flex;
		gap: 0.5rem;
	}
</style>