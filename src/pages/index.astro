---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				max-width: 750px;
				margin: 0 auto;
				padding: 3rem 1rem;
			}
			.console-log {
				background: var(--panel-color);
				border: 1px solid var(--border-color);
				border-radius: 6px;
				padding: 1.5rem;
				font-family: var(--font-mono);
			}
			.cursor {
				color: var(--accent-green);
				font-weight: bold;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="console-log">
				<p style="margin: 0 0 1rem 0; color: var(--text-muted);">// Session initialized successfully.</p>
				<h1 style="font-size: 1.7rem; margin: 0 0 1rem 0; font-family: var(--font-mono);">
					<span class="cursor">$</span> cat welcome.txt
				</h1>
				<p style="color: var(--text-main); line-height: 1.6; font-family: var(--font-sans);">
					Welcome to the archive. This platform hosts a curated collection of advanced competitive programming breakdowns, 
					theoretical notes for artificial intelligence architectures, and structured reference material mappings.
				</p>
				<p style="margin: 1.5rem 0 0 0; font-size: 0.9rem; color: var(--text-muted);">
					Navigate through <a href="/blog" style="color: var(--accent);">~/materials</a> to read optimization guides, or jump straight into the resource pools via <a href="/links" style="color: var(--accent);">~/links</a>.
				</p>
			</div>
		</main>
		<Footer />
	</body>
</html>