---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const quickLinks = [
	{ href: '/about', icon: 'ID', label: '~/hakkında', hint: 'Ben ve sitenin vizyonu' },
	{ href: '/blog', icon: 'MD', label: '~/materyaller', hint: 'Tutoriallar & kamp notları' },
	{ href: '/links', icon: 'LN', label: '~/bağlantılar', hint: 'Judge & kaynak havuzu' },
	{ href: '/problems', icon: 'AC', label: '~/problemler', hint: 'Seçilmiş olimpiyat soruları' },
	{ href: '/contact', icon: 'TX', label: '~/iletişim', hint: 'Öneri & geri bildirim' },
];
---

<!doctype html>
<html lang="tr">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="page-shell">
			<section class="terminal-panel animate-in">
				<div class="terminal-panel__bar">
					<span class="terminal-dot terminal-dot--red"></span>
					<span class="terminal-dot terminal-dot--yellow"></span>
					<span class="terminal-dot terminal-dot--green"></span>
					<span class="terminal-panel__title">seferovic — zsh</span>
				</div>
				<div class="terminal-panel__body">
					<p class="terminal-comment">// Sistem Hazır o_o</p>
					<p class="terminal-prompt">
						<span class="prompt-char">$</span> cat hoşgeldiniz.txt<span class="cursor-blink"></span>
					</p>
					<p class="terminal-copy">
						Arşive hoş geldiniz. Bu arşiv; Türkiye'de competitive programming ve IOAI
						çalışanlar için hazırladığım, kendi yolculuğumda işime yarayan kaynakları,
						problemleri ve notları bir araya getiren Türkçe bir çalışma alanı.
					</p>
					<p class="terminal-note">
						<span aria-hidden="true">-&gt;</span> Hızlı erişim aşağıda. İyi çalışmalar.
					</p>
				</div>
			</section>

			<div class="section-label animate-in animate-in--delay-1"># quick_access</div>
			<div class="nav-grid animate-in animate-in--delay-2">
				{quickLinks.map((link) => (
					<a href={link.href} class="nav-card">
						<span class="nav-card__icon">{link.icon}</span>
						<span class="nav-card__label">{link.label}</span>
						<span class="nav-card__hint">{link.hint}</span>
					</a>
				))}
			</div>
		</main>
		<Footer />
	</body>
</html>
