---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="tr">
	<head>
		<BaseHead title={`İletişim | ${SITE_TITLE}`} description="Talep veya öneri gönderme hattı." />
	</head>
	<body>
		<Header />
		<main class="page-shell">
			<PageHero
				path="/iletisim"
				description="Öneri, düzeltme veya iş birliği için mesaj bırak."
			/>

			<div class="form-panel animate-in animate-in--delay-1">
				<p class="terminal-comment" style="margin-bottom: 1.25rem;">$ ./iletisim.sh --stdin</p>

				<form action="https://formspree.io/f/xpqgrajg" method="POST">
					<label for="identity">Adınız / Kimlik:</label>
					<input type="text" id="identity" name="identity" required placeholder="Anonim..." />

					<label for="message">Mesaj / Öneri:</label>
					<textarea id="message" name="message" rows="5" required placeholder="Buraya yaz..."></textarea>

					<button type="submit" class="btn-primary">&gt; RUN_SEND</button>
				</form>
			</div>
		</main>
		<Footer />
	</body>
</html>
