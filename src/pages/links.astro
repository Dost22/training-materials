---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BaseHead from '../components/BaseHead.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const judges = [
  { name: "Codeforces Groups", url: "https://codeforces.com/group/Uo1lq8ZyWf/contests", badge: "Contests", desc: "Özel eğitim grupları ve aktif yarışma simülasyon setleri." },
  { name: "AtCoder Table", url: "https://kenkoooo.com/atcoder/#/table/", badge: "Analytics", desc: "Problem zorluk ölçekleri ve günlük seri takibi için Kenkoooo paneli." },
  { name: "oj.uz", url: "https://oj.uz/", badge: "Olimpiyat", desc: "Resmi IOI, Balkan ve CEOI problemlerine ev sahipliği yapan arşiv." },
  { name: "QOJ", url: "https://qoj.ac", badge: "Grand Prix", desc: "Üst düzey uluslararası yarışmalar ve elit eğitim kampları için ortak judge." },
  { name: "Codeforces", url: "https://codeforces.com", badge: "Global", desc: "Klasik div yarışmaları, küresel reyting takibi ve çözüm analizleri." },
  { name: "AtCoder", url: "https://atcoder.jp", badge: "Global", desc: "Matematiksel ve yapısal mantığa dayalı haftalık algoritmik yarışmalar." }
];

const references = [
  { name: "USACO Guide", url: "https://usaco.guide/", type: "Syllabus", desc: "Gümüşten platine kadar tüm paradigmaları içeren, rekabetçi programlama için en iyi rehber." },
  { name: "YouKn0wWho Academy", url: "https://youkn0wwho.academy/topic-list", type: "Topic List", desc: "Uluslararası arenalar için gereken temel ve ileri düzey algoritmik yapıların listesi." },
  { name: "Informatics Checklist", url: "https://checklist.spoi.org.in/", type: "Checklist", desc: "İleri algoritmik alanlarda durum takibi sağlamak için hazırlanmış doğrulama matrisi." },
  { name: "CSES Problem Set", url: "https://cses.fi/problemset/", type: "Core 300", desc: "DP, Graf ve Aralık Sorgularını kapsayan 300 klasik algoritmik problemden oluşan altın standart." },
  { name: "CP-Algorithms", url: "https://cp-algorithms.com/", type: "Reference", desc: "Standart algoritmalara yönelik matematiksel çıkarımlar ve karmaşıklık analizleri." },
  { name: "Mamnoon Siam Notes", url: "https://mamnoonsiam.github.io/", type: "Advanced", desc: "Üst düzey optimizasyonlar, centroid yapıları ve nadir veri sistemleri üzerine notlar." },
  { name: "USAMO Guide", url: "https://www.usamoguide.com/", type: "Math", desc: "Teorik analitik çerçeveleri güçlendirmek için matematiksel problem çözme temelleri." }
];

const literature = [
  { name: "Competitive Programmer's Handbook", url: "https://cses.fi/book/book.pdf", source: "Antti Laaksonen", desc: "Modern rekabetçi algoritmaların temel el kitabı." },
  { name: "Modern Olympiad Number Theory (MONT)", url: "https://www.cantab.net/users/aditya/books/ModernOlympiadNumberTheory.pdf", source: "Aditya Khurmi", desc: "Gelişmiş modüler aritmetik, p-adik değerlemeler ve diofant denklemleri." }
];

const aiOlympiad = [
  { name: "Google Colab", url: "https://colab.research.google.com/", tag: "IDE", desc: "Model eğitim hatları için bulut tabanlı Jupyter ortamı." },
  { name: "Olimpiada AI Romania", url: "https://platform.olimpiada-ai.ro/en", tag: "Judge", desc: "Otomatik subtask değerlendirmelerini barındıran resmi sınav ortamı." },
  { name: "Mathematics for Machine Learning (MML)", url: "https://mml-book.github.io/", tag: "Theory", desc: "Yapay zekanın temelini oluşturan lineer cebir, analitik geometri ve kalkülüs portalı." },
  { name: "MML Textbook (Tam PDF)", url: "https://mml-book.github.io/book/mml-book.pdf", tag: "Book", desc: "Matematiksel analiz için temel MML müfredatının doğrudan PDF derlemesi." },
  { name: "DeepLearning.AI", url: "https://learn.deeplearning.ai/", tag: "Courses", desc: "Model uygulamalarını ve fine-tuning mekaniklerini parçalara ayıran kısa kurs modülleri." },
  { name: "NumPy Quickstart Guide", url: "https://numpy.org/doc/stable/user/quickstart.html", tag: "Docs", desc: "Vektörleştirme, geniş dizi yapıları ve hızlı matris dönüşümleri kılavuzu." },
  { name: "Nitro-AI Preparation Hub", url: "https://olimpiada.nitro-ai.org/ro/prepare", tag: "Training", desc: "Geçmiş olimpiyat veri kümeleri, çözümler ve ortam kurulumları." },
  { name: "Pandas Cookbook", url: "https://pandas.pydata.org/pandas-docs/stable/user_guide/cookbook.html#cookbook", tag: "Docs", desc: "Veri manipülasyonu ve özellik matrisi montajı için optimizasyon yolları." },
  { name: "AI Club (Avalur)", url: "https://avalur.github.io/ai_club.html", tag: "Notes", desc: "Yapay zeka olimpiyatları için öğrenme yolları ve teorik not derlemeleri." },
  { name: "NLTK Natural Language Book", url: "https://www.nltk.org/book/ch00.html", tag: "Book", desc: "Metin vektörleştirme ve tokenizasyon paradigmaları için kesin rehber." },
  { name: "TensorFlow Playground", url: "https://playground.tensorflow.org/", tag: "Visualizer", desc: "Geri yayılımı ve aktivasyon fonksiyonlarını görselleştirmek için etkileşimli alan." }
];
---

<!doctype html>
<html lang="tr">
	<head>
		<BaseHead title={`Bağlantılar | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		</head>
	<body>
		<Header />
		<main>
			<div class="intro-block">
				<h1 style="font-family: var(--font-mono); margin: 0; font-size: 1.6rem;">~/links</h1>
				<p>Online judge'lar, dökümantasyonlar ve olimpiyat hazırlık kaynaklarının merkezi indeksi.</p>
			</div>

			<div class="section-title"># ONLINE_JUDGES</div>
			<div class="section-title"># SYLLABUS_AND_RESOURCES</div>
			
			<div class="section-title"># CORE_LITERATURE</div>
			
			<div class="section-title"># MACHINE_LEARNING_THEORY</div>
		</main>
		<Footer />
	</body>
</html>