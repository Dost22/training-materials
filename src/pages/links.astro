---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BaseHead from '../components/BaseHead.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const judges = [
  { name: "Codeforces Groups", url: "https://codeforces.com/group/Uo1lq8ZyWf/contests", badge: "Contests", desc: "Özel eğitim grupları ve aktif yarışma simülasyon setleri." },
  { name: "AtCoder Table", url: "https://kenkoooo.com/atcoder/#/table/", badge: "Analytics", desc: "Problem zorluk ölçekleri ve günlük seri takibi için Kenkoooo paneli." },
  { name: "oj.uz", url: "https://oj.uz/", badge: "Olimpiyat", desc: "Resmi IOI, Balkan ve CEOI problemlerine ev sahipliği yapan arşiv." },
  { name: "QOJ", url: "https://qoj.ac", badge: "Grand Prix", desc: "Üst düzey uluslararası yarışmalar ve elit eğitim kampları için ortak judge." },
  { name: "Codeforces", url: "https://codeforces.com", badge: "Global", desc: "Klasik div yarışmaları, küresel reyting takibi ve çözüm analizleri." },
  { name: "AtCoder", url: "https://atcoder.jp", badge: "Global", desc: "Matematiksel ve yapısal mantığa dayalı haftalık algoritmik yarışmalar." }
];

const references = [
  { name: "USACO Guide", url: "https://usaco.guide/", type: "Syllabus", desc: "Gümüşten platine kadar tüm paradigmaları içeren, rekabetçi programlama için en iyi rehber." },
  { name: "YouKn0wWho Academy", url: "https://youkn0wwho.academy/topic-list", type: "Topic List", desc: "Uluslararası arenalar için gereken temel ve ileri düzey algoritmik yapıların listesi." },
  { name: "Informatics Checklist", url: "https://checklist.spoi.org.in/", type: "Checklist", desc: "İleri algoritmik alanlarda durum takibi sağlamak için hazırlanmış doğrulama matrisi." },
  { name: "CSES Problem Set", url: "https://cses.fi/problemset/", type: "Core 300", desc: "DP, Graf ve Aralık Sorgularını kapsayan 300 klasik algoritmik problemden oluşan altın standart." },
  { name: "CP-Algorithms", url: "https://cp-algorithms.com/", type: "Reference", desc: "Standart algoritmalara yönelik matematiksel çıkarımlar ve karmaşıklık analizleri." },
  { name: "Mamnoon Siam Notes", url: "https://mamnoonsiam.github.io/", type: "Advanced", desc: "Üst düzey optimizasyonlar, centroid yapıları ve nadir veri sistemleri üzerine notlar." },
  { name: "USAMO Guide", url: "https://www.usamoguide.com/", type: "Math", desc: "Teorik analitik çerçeveleri güçlendirmek için matematiksel problem çözme temelleri." }
];

const literature = [
  { name: "Competitive Programmer's Handbook", url: "https://cses.fi/book/book.pdf", source: "Antti Laaksonen", desc: "Modern rekabetçi algoritmaların temel el kitabı." },
  { name: "Modern Olympiad Number Theory (MONT)", url: "https://www.cantab.net/users/aditya/books/ModernOlympiadNumberTheory.pdf", source: "Aditya Khurmi", desc: "Gelişmiş modüler aritmetik, p-adik değerlemeler ve diofant denklemleri." }
];

const aiOlympiad = [
  { name: "Google Colab", url: "https://colab.research.google.com/", tag: "IDE", desc: "Model eğitim hatları için bulut tabanlı Jupyter ortamı." },
  { name: "Olimpiada AI Romania", url: "https://platform.olimpiada-ai.ro/en", tag: "Judge", desc: "Otomatik subtask değerlendirmelerini barındıran resmi sınav ortamı." },
  { name: "Mathematics for Machine Learning (MML)", url: "https://mml-book.github.io/", tag: "Theory", desc: "Yapay zekanın temelini oluşturan lineer cebir, analitik geometri ve kalkülüs portalı." },
  { name: "MML Textbook (Tam PDF)", url: "https://mml-book.github.io/book/mml-book.pdf", tag: "Book", desc: "Matematiksel analiz için temel MML müfredatının doğrudan PDF derlemesi." },
  { name: "DeepLearning.AI", url: "https://learn.deeplearning.ai/", tag: "Courses", desc: "Model uygulamalarını ve fine-tuning mekaniklerini parçalara ayıran kısa kurs modülleri." },
  { name: "NumPy Quickstart Guide", url: "https://numpy.org/doc/stable/user/quickstart.html", tag: "Docs", desc: "Vektörleştirme, geniş dizi yapıları ve hızlı matris dönüşümleri kılavuzu." },
  { name: "Nitro-AI Preparation Hub", url: "https://olimpiada.nitro-ai.org/ro/prepare", tag: "Training", desc: "Geçmiş olimpiyat veri kümeleri, çözümler ve ortam kurulumları." },
  { name: "Pandas Cookbook", url: "https://pandas.pydata.org/pandas-docs/stable/user_guide/cookbook.html#cookbook", tag: "Docs", desc: "Veri çerçevesi temizleme, yapısal dilimleme ve özellik matrisi montajı için optimizasyon yolları." },
  { name: "AI Club (Avalur)", url: "https://avalur.github.io/ai_club.html", tag: "Notes", desc: "Özel yapay zeka havuzları için öğrenme yolları, algoritmik teori ve yarışma ipuçlarının yoğun derlemesi." },
  { name: "NLTK Natural Language Book", url: "https://www.nltk.org/book/ch00.html", tag: "Book", desc: "Linguistik veri ayrıştırma, metin vektörleştirme ve tokenizasyon paradigmaları için kesin rehber." },
  { name: "TensorFlow Playground", url: "https://playground.tensorflow.org/", tag: "Visualizer", desc: "Geri yayılımı, aktivasyon eşiklerini ve özellik haritalarını görselleştirmek için etkileşimli sinir ağı alanı." }
];

const youtubeChannels = [
  { name: "Errichto", url: "https://www.youtube.com/@Errichto", tag: "Algorithms", desc: "Klasik algoritmik paradigmalar, binary search hileleri ve hem standart hem de ileri düzey (hard) problem çözme yayınları." },
  { name: "William Fiset", url: "https://www.youtube.com/@WilliamFiset", tag: "Graph / DS", desc: "Graf teorisi, veri yapıları ve dinamik programlama üzerine sektör standardı temiz görsel anlatımlar." },
  { name: "SecondThread", url: "https://www.youtube.com/@SecondThread", tag: "CP / Tutorials", desc: "Sıra dışı veri yapıları, Codeforces turları ve algoritma kampları için hazırladığı ileri düzey oynatma listeleri." },
  { name: "Algorithms Live!", url: "https://www.youtube.com/@AlgorithmsLive", tag: "Advanced CP", desc: "Uluslararası arenalardan (ICPC, IOI) elit algoritmaların canlı kodlama ve tahta üzerinde derinlemesine analizi." },
  { name: "Pavel Mavrin", url: "https://www.youtube.com/@PavelMavrin", tag: "Theory / Rus", desc: "St Petersburg ekolünden, enformatik olimpiyatları seviyesinde matematiksel ve yapısal algoritma kanıtları." },
  { name: "Radoslav Dimitrov", url: "https://www.youtube.com/@RadoslavDimitrov", tag: "IOI / CP", desc: "Balkan ve uluslararası olimpiyat düzeyinde gelişmiş veri yapıları (Segment Tree varyasyonları) ve problem analizleri." }
];
---

<!doctype html>
<html lang="tr">
	<head>
		<BaseHead title={`Bağlantılar | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			main {
				max-width: 960px;
				margin: 0 auto;
				padding: 3rem 1.5rem;
				box-sizing: border-box;
			}
			.intro-block {
				margin-bottom: 2.5rem;
				border-left: 3px solid var(--accent-green);
				padding-left: 1.2rem;
			}
			.intro-block p {
				color: var(--text-muted);
				font-size: 0.95rem;
				margin: 0.4rem 0 0 0;
			}
			.section-title {
				font-family: var(--font-mono);
				color: var(--accent-green);
				font-size: 0.95rem;
				font-weight: 600;
				margin: 3rem 0 1.2rem 0;
				letter-spacing: 0.5px;
				border-bottom: 1px dashed var(--border-color);
				padding-bottom: 0.4rem;
			}
			
			/* GRID PANELS */
			.judge-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
				gap: 0.85rem;
				list-style-type: none;
				padding: 0;
				margin: 0;
			}
			
			@media (max-width: 720px) {
				.judge-grid {
					grid-template-columns: 1fr;
					gap: 0.5rem;
				}
				main {
					padding: 1.5rem 1rem;
				}
			}

			.judge-card {
				background: var(--panel-color);
				border: 1px solid var(--border-color);
				border-radius: 6px;
				padding: 1rem;
				text-decoration: none;
				display: flex;
				flex-direction: column;
				transition: border-color 0.12s ease, box-shadow 0.12s ease;
			}
			.judge-card:hover {
				border-color: var(--accent);
				text-decoration: none;
				box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
			}
			.card-header {
				display: flex;
				justify-content: space-between;
				align-items: center;
				margin-bottom: 0.5rem;
			}
			.card-title {
				color: var(--accent);
				font-weight: 600;
				font-size: 0.95rem;
			}
			.badge {
				font-family: var(--font-mono);
				font-size: 0.75rem;
				background: rgba(88, 166, 255, 0.1);
				color: var(--accent);
				padding: 0.15rem 0.45rem;
				border-radius: 4px;
				border: 1px solid rgba(88, 166, 255, 0.2);
			}
			.card-desc {
				color: var(--text-main);
				font-size: 0.85rem;
				margin: 0;
				line-height: 1.45;
			}
			
			/* LIST MATRIX ROW PANELS */
			.ref-list {
				display: flex;
				flex-direction: column;
				gap: 0.6rem;
				list-style-type: none;
				padding: 0;
				margin: 0;
			}
			.ref-row {
				display: flex;
				align-items: flex-start;
				background: var(--panel-color);
				border: 1px solid var(--border-color);
				border-radius: 6px;
				padding: 1rem 1.2rem;
				text-decoration: none;
				transition: border-color 0.12s ease, transform 0.12s ease;
			}
			.ref-row:hover {
				border-color: var(--accent-green);
				transform: translateX(3px);
				text-decoration: none;
			}
			
			@media (max-width: 600px) {
				.ref-row {
					flex-direction: column;
					gap: 0.4rem;
				}
				.type-tag {
					min-width: auto !important;
				}
			}

			.type-tag {
				font-family: var(--font-mono);
				font-size: 0.75rem;
				color: var(--text-muted);
				min-width: 140px;
				padding-top: 0.1rem;
				flex-shrink: 0;
			}
			.ref-content {
				display: flex;
				flex-direction: column;
				flex-grow: 1;
			}
			.ref-title {
				color: var(--accent);
				font-weight: 600;
				font-size: 0.95rem;
			}
			.ref-desc {
				color: var(--text-main);
				font-size: 0.85rem;
				margin: 0.25rem 0 0 0;
				line-height: 1.45;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="intro-block">
				<h1 style="font-family: var(--font-mono); margin: 0; font-size: 1.6rem; color: var(--text-main);">~/links</h1>
				<p>Online judge'lar, dökümantasyonlar ve olimpiyat hazırlık kaynaklarının merkezi indeksi.</p>
			</div>

			<div class="section-title"># ONLINE_JUDGES</div>
			<div class="judge-grid">
				{judges.map((j) => (
					<a href={j.url} target="_blank" rel="noopener noreferrer" class="judge-card">
						<div class="card-header">
							<span class="card-title">{j.name} ↗</span>
							<span class="badge">{j.badge}</span>
						</div>
						<p class="card-desc">{j.desc}</p>
					</a>
				))}
			</div>

			<div class="section-title"># SYLLABUS_AND_RESOURCES</div>
			<div class="ref-list">
				{references.map((r) => (
					<a href={r.url} target="_blank" rel="noopener noreferrer" class="ref-row">
						<div class="type-tag">[{r.type}]</div>
						<div class="ref-content">
							<span class="ref-title">{r.name} ↗</span>
							<p class="ref-desc">{r.desc}</p>
						</div>
					</a>
				))}
			</div>

			<div class="section-title"># CORE_LITERATURE</div>
			<div class="ref-list">
				{literature.map((l) => (
					<a href={l.url} target="_blank" rel="noopener noreferrer" class="ref-row">
						<div class="type-tag" style="color: var(--accent);">[Literature]</div>
						<div class="ref-content">
							<span class="ref-title">{l.name} <span style="font-size: 0.8rem; color: var(--text-muted); font-weight: normal;">— {l.source}</span> ↗</span>
							<p class="ref-desc">{l.desc}</p>
						</div>
					</a>
				))}
			</div>

			<div class="section-title"># MACHINE_LEARNING_THEORY</div>
			<div class="ref-list">
				{aiOlympiad.map((ai) => (
					<a href={ai.url} target="_blank" rel="noopener noreferrer" class="ref-row">
						<div class="type-tag" style="color: #d19a66;">/* {ai.tag} */</div>
						<div class="ref-content">
							<span class="ref-title">{ai.name} ↗</span>
							<p class="ref-desc">{ai.desc}</p>
						</div>
					</a>
				))}
			</div>

			<div class="section-title"># RECOMMENDED_YOUTUBE_CHANNELS</div>
			<div class="ref-list">
				{youtubeChannels.map((yt) => (
					<a href={yt.url} target="_blank" rel="noopener noreferrer" class="ref-row">
						<div class="type-tag" style="color: #ff5555;">[YT // {yt.tag}]</div>
						<div class="ref-content">
							<span class="ref-title">{yt.name} ↗</span>
							<p class="ref-desc">{yt.desc}</p>
						</div>
					</a>
				))}
			</div>
		</main>
		<Footer />
	</body>
</html>