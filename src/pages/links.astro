---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BaseHead from '../components/BaseHead.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const judges = [
  { name: "Codeforces Groups", url: "https://codeforces.com/group/Uo1lq8ZyWf/contests", badge: "Contests", desc: "Private training group, active contest simulation sets, and custom mashups." },
  { name: "AtCoder Table", url: "https://kenkoooo.com/atcoder/#/table/", badge: "Analytics", desc: "Kenkoooo tracking dashboard for absolute problem difficulty scales and streak maintenance." },
  { name: "oj.uz", url: "https://oj.uz/", badge: "Olympiad", desc: "Premium international informatics arena hosting official IOI, Balkan, and CEOI tasks." },
  { name: "QOJ", url: "https://qoj.ac", badge: "Grand Prix", desc: "Universal judge hosting high-tier multi-provincial contests and elite training camps." },
  { name: "Codeforces", url: "https://codeforces.com", badge: "Global", desc: "Main server for division rounds, global rating maintenance, and post-match editorials." },
  { name: "AtCoder", url: "https://atcoder.jp", badge: "Global", desc: "Weekly high-quality algorithmic rounds emphasizing pure structural logic and math." }
];

const references = [
  { name: "USACO Guide", url: "https://usaco.guide/", type: "Syllabus", desc: "The definitive structured handbook for competitive programming, tracking silver through platinum paradigms." },
  { name: "YouKn0wWho Academy", url: "https://youkn0wwho.academy/topic-list", type: "Topic Tree", desc: "Comprehensive collection of fundamental and advanced algorithmic structures needed for international pools." },
  { name: "Informatics Checklist", url: "https://checklist.spoi.org.in/", type: "Tracker", desc: "Granular verification matrix ensuring full mastery across advanced algorithmic subfields." },
  { name: "CSES Problem Set", url: "https://cses.fi/problemset/", type: "Core 300", desc: "The gold standard collection of 300 classic algorithmic problems spanning DP, Graphs, and Range Queries." },
  { name: "CP-Algorithms", url: "https://cp-algorithms.com/", type: "Reference", desc: "Mathematical derivations, visual walkthroughs, and rigid complexity analyses for standard paradigms." },
  { name: "Mamnoon Siam Notes", url: "https://mamnoonsiam.github.io/", type: "Advanced", desc: "Elite curation of high-level optimization tricks, centroid structures, and obscure data systems." },
  { name: "USAMO Guide", url: "https://www.usamoguide.com/", type: "Math", desc: "Mathematical problem-solving foundation to reinforce theoretical analytical frameworks." }
];

const literature = [
  { name: "Competitive Programmer's Handbook", url: "https://cses.fi/book/book.pdf", source: "Antti Laaksonen", desc: "The foundational text for modern competitive algorithms. Clean layouts covering everything from range updates to string hashing." },
  { name: "Modern Olympiad Number Theory (MONT)", url: "https://www.cantab.net/users/aditya/books/ModernOlympiadNumberTheory.pdf", source: "Aditya Khurmi", desc: "Elite mathematical foundation tracking advanced modular arithmetic, p-adic valuations, and diophantine structures." }
];

const aiOlympiad = [
  { name: "Google Colab", url: "https://colab.research.google.com/", tag: "IDE", desc: "Cloud-hosted Jupyter environment utilized for interactive prototyping and model training pipelines." },
  { name: "Olimpiada AI Romania", url: "https://platform.olimpiada-ai.ro/en", tag: "Judge", desc: "Official examination and testing environment hosting structured tasks and automated subtask evaluations." },
  { name: "Mathematics for Machine Learning (MML)", url: "https://mml-book.github.io/", tag: "Theory Hub", desc: "Comprehensive portal tracking the vector spaces, matrix factorizations, and multi-variable calculus underlying machine learning." },
  { name: "MML Textbook (Full PDF)", url: "https://mml-book.github.io/book/mml-book.pdf", tag: "Textbook", desc: "Direct compilation of the foundational MML syllabus for offline mathematical analysis." },
  { name: "DeepLearning.AI", url: "https://learn.deeplearning.ai/", tag: "Syllabus", desc: "Short-course modules breaking down structural model implementations and fine-tuning mechanics." },
  { name: "NumPy Quickstart Guide", url: "https://numpy.org/doc/stable/user/quickstart.html", tag: "Docs", desc: "Reference handbook outlining vectorization, broad array structures, and efficient coordinate transformations." },
  { name: "Nitro-AI Preparation Hub", url: "https://olimpiada.nitro-ai.org/ro/prepare", tag: "Training", desc: "Targeted competitive training modules, past olympiad datasets, and environment setups." },
  { name: "Pandas Cookbook", url: "https://pandas.pydata.org/pandas-docs/stable/user_guide/cookbook.html#cookbook", tag: "Docs", desc: "Granular idioms and optimization paths for dataframe cleaning, structural slicing, and feature matrix assembly." },
  { name: "AI Club (Avalur)", url: "https://avalur.github.io/ai_club.html", tag: "Curated Notes", desc: "Dense, elite compilation of learning paths, algorithmic theory, and competition tricks for specialized AI pools." },
  { name: "NLTK Natural Language Book", url: "https://www.nltk.org/book/ch00.html", tag: "Textbook", desc: "The definitive guide to linguistic data parsing, text vectorization, and tokenization paradigms." },
  { name: "TensorFlow Playground", url: "https://playground.tensorflow.org/", tag: "Visualizer", desc: "Interactive neural network playground for visualizing backpropagation, activation thresholds, and feature maps." }
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Engineering Index | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			main {
				max-width: 800px;
				margin: 0 auto;
				padding: 2rem 1rem;
			}
			.intro-block {
				margin-bottom: 2rem;
				border-left: 3px solid var(--accent-green);
				padding-left: 1rem;
			}
			.intro-block p {
				color: var(--text-muted);
				font-size: 0.95rem;
				margin: 0.25rem 0 0 0;
			}
			.section-title {
				font-family: var(--font-mono);
				color: var(--accent-green);
				font-size: 0.95rem;
				font-weight: 600;
				margin: 2.5rem 0 1rem 0;
				letter-spacing: 0.5px;
			}
			
			/* Active Judges Layout - Dense 2-Column Grid */
			.judge-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
				gap: 0.75rem;
			}
			.judge-card {
				background: var(--panel-color);
				border: 1px solid var(--border-color);
				border-radius: 6px;
				padding: 0.85rem;
				text-decoration: none;
				display: flex;
				flex-direction: column;
				transition: border-color 0.12s ease;
			}
			.judge-card:hover {
				border-color: var(--accent);
				text-decoration: none;
			}
			.card-header {
				display: flex;
				justify-content: space-between;
				align-items: center;
				margin-bottom: 0.35rem;
			}
			.card-title {
				color: var(--accent);
				font-weight: 600;
				font-size: 0.95rem;
			}
			.judge-card:hover .card-title {
				color: #f0f6fc;
				text-decoration: underline;
			}
			.badge {
				font-family: var(--font-mono);
				font-size: 0.75rem;
				background: rgba(88, 166, 255, 0.1);
				color: var(--accent);
				padding: 0.15rem 0.4rem;
				border-radius: 4px;
				border: 1px solid rgba(88, 166, 255, 0.2);
			}
			.card-desc {
				color: var(--text-main);
				font-size: 0.85rem;
				margin: 0;
				line-height: 1.4;
			}

			/* Reference List Layout - Clean Dense Rows */
			.ref-list {
				display: flex;
				flex-direction: column;
				gap: 0.5rem;
			}
			.ref-row {
				display: flex;
				align-items: flex-start;
				background: var(--panel-color);
				border: 1px solid var(--border-color);
				border-radius: 6px;
				padding: 0.75rem 1rem;
				text-decoration: none;
				transition: border-color 0.12s ease, transform 0.12s ease;
			}
			.ref-row:hover {
				border-color: var(--accent-green);
				transform: translateX(3px);
				text-decoration: none;
			}
			.type-tag {
				font-family: var(--font-mono);
				font-size: 0.75rem;
				color: var(--text-muted);
				min-width: 100px;
				padding-top: 0.15rem;
			}
			.ref-content {
				display: flex;
				flex-direction: column;
				flex-grow: 1;
			}
			.ref-title {
				color: var(--accent);
				font-weight: 600;
				font-size: 0.95rem;
			}
			.ref-row:hover .ref-title {
				color: var(--accent-green);
			}
			.ref-desc {
				color: var(--text-main);
				font-size: 0.85rem;
				margin: 0.15rem 0 0 0;
				line-height: 1.4;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="intro-block">
				<h1 style="font-family: var(--font-mono); margin: 0; font-size: 1.6rem;">~/olympiad-dashboard</h1>
				<p>A centralized indexing of core judges, artificial intelligence theory environments, and curriculum trackers.</p>
			</div>

			<!-- Core Evaluation Hubs -->
			<div class="section-title"># IOI_ACTIVE_EVALUATION_ENVIRONMENTS</div>
			<div class="judge-grid">
				{judges.map((j) => (
					<a href={j.url} target="_blank" rel="noopener noreferrer" class="judge-card">
						<div class="card-header">
							<span class="card-title">{j.name} ↗</span>
							<span class="badge">{j.badge}</span>
						</div>
						<p class="card-desc">{j.desc}</p>
					</a>
				))}
			</div>

			<!-- Curated Syllabus and Guides -->
			<div class="section-title"># IOI_CORE_THEORY_AND_CURRICULUM_MATRICES</div>
			<div class="ref-list">
				{references.map((r) => (
					<a href={r.url} target="_blank" rel="noopener noreferrer" class="ref-row">
						<div class="type-tag">[{r.type}]</div>
						<div class="ref-content">
							<span class="ref-title">{r.name} ↗</span>
							<p class="ref-desc">{r.desc}</p>
						</div>
					</a>
				))}
			</div>

			<!-- Core Mathematical & Algorithmic Literature -->
			<div class="section-title"># REQUISITE_CORE_LITERATURE</div>
			<div class="ref-list">
				{literature.map((l) => (
					<a href={l.url} target="_blank" rel="noopener noreferrer" class="ref-row">
						<div class="type-tag" style="color: var(--accent);">[LIT]</div>
						<div class="ref-content">
							<span class="ref-title">{l.name} <span style="font-size: 0.8rem; color: var(--text-muted); font-weight: normal;">— {l.source}</span> ↗</span>
							<p class="ref-desc">{l.desc}</p>
						</div>
					</a>
				))}
			</div>

			<!-- IOAI Architecture & Foundations -->
			<div class="section-title"># IOAI_ARTIFICIAL_INTELLIGENCE_FOUNDATIONS</div>
			<div class="ref-list">
				{aiOlympiad.map((ai) => (
					<a href={ai.url} target="_blank" rel="noopener noreferrer" class="ref-row">
						<div class="type-tag" style="color: #d19a66;">/* {ai.tag} */</div>
						<div class="ref-content">
							<span class="ref-title">{ai.name} ↗</span>
							<p class="ref-desc">{ai.desc}</p>
						</div>
					</a>
				))}
			</div>
		</main>
		<Footer />
	</body>
</html>