---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BaseHead from '../components/BaseHead.astro';
import PageHero from '../components/PageHero.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const judges = [
  { name: "AtCoder Table", url: "https://kenkoooo.com/atcoder/#/table/", badge: "Analytics", desc: "Atcoder problem arşivi" },
  { name: "oj.uz", url: "https://oj.uz/", badge: "Olimpiyat", desc: "Birçok OI problemini içeren arşiv." },
  { name: "QOJ", url: "https://qoj.ac", badge: "Grand Prix", desc: "Günümüzün en kapsamlı judge'ı" },
  { name: "Codeforces", url: "https://codeforces.com", badge: "Global", desc: "En büyük ve popüler ICPC sitesi" },
  { name: "AtCoder", url: "https://atcoder.jp", badge: "Global", desc: "Algodan çok matematik ve mantığa dayalı haftalık algoritmik yarışmalar." }
];

const references = [
  { name: "USACO Guide", url: "https://usaco.guide/", type: "Syllabus", desc: "Rekabetçi programlama için en iyi kaynak." },
  { name: "YouKn0wWho Academy", url: "https://youkn0wwho.academy/topic-list", type: "Topic List", desc: "Aklınıza gelicek her konuda envai çeşit soru." },
  { name: "Informatics Checklist", url: "https://checklist.spoi.org.in/", type: "Checklist", desc: "Olimpiyat sorularında durum takibi sağlamak için checklist." },
  { name: "CSES Problem Set", url: "https://cses.fi/problemset/", type: "Core 300", desc: "DP, Graf ve Aralık Sorgularını kapsayan 300 klasik algoritmik problemden oluşan altın standart." },
  { name: "CP-Algorithms", url: "https://cp-algorithms.com/", type: "Reference", desc: "Standart algoritmalara yönelik matematiksel çıkarımlar ve karmaşıklık analizleri." },
  { name: "Mamnoon Siam Notes", url: "https://mamnoonsiam.github.io/", type: "Advanced", desc: "Obscure olmakla beraber fevkalade kaynaklar" },
  { name: "USAMO Guide", url: "https://www.usamoguide.com/", type: "Math", desc: "Yepyeni (iyi bir şey mi bilmem) USACO matematik klonu." }
];

const literature = [
  { name: "Competitive Programmer's Handbook", url: "https://cses.fi/book/book.pdf", source: "Antti Laaksonen", desc: "CP holy bible" },
  { name: "Modern Olympiad Number Theory (MONT)", url: "https://www.cantab.net/users/aditya/books/ModernOlympiadNumberTheory.pdf", source: "Aditya Khurmi", desc: "Sonlu matematiğe beginner-friendly bir giriş. (link bozuk siz bir yolunu bulursunuz ;) )" }
];

const aiOlympiad = [
  { name: "Google Colab", url: "https://colab.research.google.com/", tag: "IDE", desc: "Model eğitim hatları için bulut tabanlı Jupyter ortamı." },
  { name: "Olimpiada AI Romania", url: "https://platform.olimpiada-ai.ro/en", tag: "Judge", desc: "EN ÖNEMLİ KAYNAK!!!" },
  { name: "Mathematics for Machine Learning (MML)", url: "https://mml-book.github.io/", tag: "Theory", desc: "Yapay zekanın temelini oluşturan lineer cebir, analitik geometri ve kalkülüs portalı." },
  { name: "MML Textbook (Tam PDF)", url: "https://mml-book.github.io/book/mml-book.pdf", tag: "Book", desc: "Matematiksel analiz için temel MML müfredatının doğrudan PDF derlemesi." },
  { name: "DeepLearning.AI", url: "https://learn.deeplearning.ai/", tag: "Courses", desc: "Model uygulamalarını ve fine-tuning mekaniklerini parçalara ayıran kısa kurs modülleri." },
  { name: "NumPy Quickstart Guide", url: "https://numpy.org/doc/stable/user/quickstart.html", tag: "Docs", desc: "Vektörleştirme, geniş dizi yapıları ve hızlı matris dönüşümleri kılavuzu." },
  { name: "Pandas Cookbook", url: "https://pandas.pydata.org/pandas-docs/stable/user_guide/cookbook.html#cookbook", tag: "Docs", desc: "İleri ML trikleri" },
  { name: "AI Club (Avalur)", url: "https://avalur.github.io/ai_club.html", tag: "Notes", desc: "Özel yapay zeka havuzları için öğrenme yolları, algoritmik teori ve yarışma ipuçlarının yoğun derlemesi." },
  { name: "NLTK Natural Language Book", url: "https://www.nltk.org/book/ch00.html", tag: "Book", desc: "Linguistik veri ayrıştırma, metin vektörleştirme ve tokenizasyon paradigmaları için kesin rehber." },
  { name: "TensorFlow Playground", url: "https://playground.tensorflow.org/", tag: "Visualizer", desc: "Neural Network temellerini görselleştirmek için etkileşimli sinir ağı alanı." }
];

const youtubeChannels = [
  { name: "Errichto", url: "https://www.youtube.com/@Errichto", tag: "Algorithms", desc: "Klasik algoritmik paradigmalar, binary search hileleri ve hem standart hem de ileri düzey (hard) problem çözme yayınları." },
  { name: "William Fiset", url: "https://www.youtube.com/@WilliamFiset", tag: "Graph / DS", desc: "Graf teorisi, veri yapıları ve dinamik programlama üzerine sektör standardı temiz görsel anlatımlar." },
  { name: "SecondThread", url: "https://www.youtube.com/@SecondThread", tag: "CP / Tutorials", desc: "Sıra dışı veri yapıları, Codeforces roundları ve algoritma kampları için hazırladığı ileri düzey oynatma listeleri." },
  { name: "Algorithms Live!", url: "https://www.youtube.com/@AlgorithmsLive", tag: "Advanced CP", desc: "Çok kapsamlı kaliteli konu anlatımı." },
  { name: "Pavel Mavrin", url: "https://www.youtube.com/@PavelMavrin", tag: "Theory / Rus", desc: "Dev Rigorous Arşiv." },
  { name: "Radoslav Dimitrov", url: "https://www.youtube.com/@radoslav11", tag: "IOI / CP", desc: "Gelişmiş veri yapıları." }
];
---

<!doctype html>
<html lang="tr">
	<head>
		<BaseHead title={`Bağlantılar | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="page-shell page-shell--wide">
			<PageHero
				path="/links"
				description="Online judge'lar, dökümantasyonlar ve olimpiyat hazırlık kaynaklarının merkezi indeksi."
			/>

			<section>
				<h2 class="section-label"># online_judges</h2>
				<div class="card-grid">
					{judges.map((j) => (
						<a href={j.url} target="_blank" rel="noopener noreferrer" class="resource-card">
							<div class="resource-card__header">
								<span class="resource-card__title">{j.name} ↗</span>
								<span class="badge">{j.badge}</span>
							</div>
							<p class="resource-card__desc">{j.desc}</p>
						</a>
					))}
				</div>
			</section>

			<section>
				<h2 class="section-label"># syllabus_and_resources</h2>
				<div class="ref-list">
					{references.map((r) => (
						<a href={r.url} target="_blank" rel="noopener noreferrer" class="ref-row">
							<span class="ref-row__tag">[{r.type}]</span>
							<div>
								<span class="ref-row__title">{r.name} ↗</span>
								<p class="ref-row__desc">{r.desc}</p>
							</div>
						</a>
					))}
				</div>
			</section>

			<section>
				<h2 class="section-label"># core_literature</h2>
				<div class="ref-list">
					{literature.map((l) => (
						<a href={l.url} target="_blank" rel="noopener noreferrer" class="ref-row">
							<span class="ref-row__tag ref-row__tag--accent">[Literature]</span>
							<div>
								<span class="ref-row__title">
									{l.name}
									<span class="ref-row__meta"> — {l.source}</span>
									↗
								</span>
								<p class="ref-row__desc">{l.desc}</p>
							</div>
						</a>
					))}
				</div>
			</section>

			<section>
				<h2 class="section-label"># machine_learning_theory</h2>
				<div class="ref-list">
					{aiOlympiad.map((ai) => (
						<a href={ai.url} target="_blank" rel="noopener noreferrer" class="ref-row">
							<span class="ref-row__tag ref-row__tag--purple">/* {ai.tag} */</span>
							<div>
								<span class="ref-row__title">{ai.name} ↗</span>
								<p class="ref-row__desc">{ai.desc}</p>
							</div>
						</a>
					))}
				</div>
			</section>

			<section>
				<h2 class="section-label"># recommended_youtube</h2>
				<div class="ref-list">
					{youtubeChannels.map((yt) => (
						<a href={yt.url} target="_blank" rel="noopener noreferrer" class="ref-row">
							<span class="ref-row__tag ref-row__tag--red">[YT // {yt.tag}]</span>
							<div>
								<span class="ref-row__title">{yt.name} ↗</span>
								<p class="ref-row__desc">{yt.desc}</p>
							</div>
						</a>
					))}
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
