---

<!doctype html>
<html lang="tr">
	<head>
		<BaseHead title={`Problemler | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="page-shell page-shell--wide">
			<PageHero
				path="/problemler"
				description="Aklıma gelen sevdiğim soruların listesi: IOI, APIO, JOI ve daha fazlası."
			/>

			{problemPool.map((group) => (
				<section>
					<h2 class="section-label"># {group.category}</h2>
					<div class="prob-grid">
						{group.problems.map((prob) => (
							<a
								href={prob.url}
								target="_blank"
								rel="noopener noreferrer"
								class="prob-card"
							>
								<span class="prob-card__run">RUN</span>
								<span class="prob-card__title">{prob.name} ↗</span>
							</a>
						))}
					</div>
				</section>
			))}
		</main>
		<Footer />
	</body>
</html>
