---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import PageHero from '../components/PageHero.astro';
import { SITE_TITLE } from '../consts';

const focusAreas = [
	{
		label: 'CP',
		title: 'Deneyimden süzülen notlar',
		description:
			'Kendi hazırlık sürecimde gerçekten işime yarayan problem, konu ve kaynakları daha düzenli bir yerde topluyorum.',
	},
	{
		label: 'TR',
		title: 'Türkçe kaynak eksikliği',
		description:
			'UBİLO kapandıktan sonra Türk CP camiasının sık kullandığı merkezi kaynaklardan biri kayboldu. Türkçe CP içeriği de hala çok sınırlı.',
	},
	{
		label: 'AI',
		title: 'IOAI ve yeni alanlar',
		description:
			'Kısa süre ilgilendiğim IOAI ve yapay zeka olimpiyatı tarafındaki kaynakları da zamanla algoritma arşivinin yanına eklemek istiyorum.',
	},
];

const principles = [
	'Kendi CP yolculuğumda gerçekten işime yarayan içerikleri paylaşmak.',
	'Gerekli gördüğüm yabancı kaynakları çevirerek veya yeniden anlatarak Türkçe bloglar haline getirmek.',
	'Problem listelerini, konu anlatımlarını ve bağlantıları tek bir düzenli arşivde toplamak.',
	'Uzun vadede daha çok kişinin katkı verip büyütebileceği bir Türk CP topluluk sitesine dönüşmek.',
];
---

<!doctype html>
<html lang="tr">
	<head>
		<BaseHead
			title={`Hakkında | ${SITE_TITLE}`}
			description="Dost Seferoğlu, yarışma geçmişi ve Seferovic Türk CP arşivinin vizyonu."
		/>
	</head>
	<body>
		<Header />
		<main class="page-shell page-shell--wide">
			<PageHero
				path="/hakkında"
				description="Ben kimim, bu arşiv neden var ve uzun vadede nereye dönüşmesini istiyorum?"
			/>

			<section class="terminal-panel animate-in animate-in--delay-1">
				<div class="terminal-panel__bar">
					<span class="terminal-dot terminal-dot--red"></span>
					<span class="terminal-dot terminal-dot--yellow"></span>
					<span class="terminal-dot terminal-dot--green"></span>
					<span class="terminal-panel__title">whoami</span>
				</div>
				<div class="terminal-panel__body about-intro">
					<p class="terminal-comment">// kısa cevap</p>
					<h2>Ben Dost Seferoğlu.</h2>
					<p>
						Türkiye'nin 2025 IOI takım üyelerinden biriyim; CP yolculuğumda ulusal altın ve
						Balkan gümüş madalyam var. Kısa bir süre IOAI ve yapay zeka olimpiyatı tarafıyla
						da ilgilendim.
					</p>
					<p>
						Seferovic'i, kendi çalışırken kullandığım içerikleri kaybolmayacak ve başkalarının
						da işine yarayacak şekilde paylaşmak için oluşturdum. Amaç sadece link biriktirmek
						değil; gerektiğinde kaynakları çevirmek, açıklamak ve Türkçe CP tarafında daha
						kalıcı bir arşiv bırakmak.
					</p>
				</div>
			</section>

			<h2 class="section-label"># neden_bu_site</h2>
			<div class="card-grid">
				{focusAreas.map((item) => (
					<article class="resource-card about-card">
						<div class="resource-card__header">
							<span class="resource-card__title">{item.title}</span>
							<span class="badge badge--green">{item.label}</span>
						</div>
						<p class="resource-card__desc">{item.description}</p>
					</article>
				))}
			</div>

			<h2 class="section-label"># arşiv_prensipleri</h2>
			<div class="ref-list">
				{principles.map((principle, index) => (
					<div class="ref-row about-row">
						<span class="ref-row__tag">[{String(index + 1).padStart(2, '0')}]</span>
						<p class="ref-row__desc">{principle}</p>
					</div>
				))}
			</div>
		</main>
		<Footer />
	</body>
</html>
